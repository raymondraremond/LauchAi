# LaunchAI Environment Variables
# ─────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit your real .env file to git.
# ─────────────────────────────────────────────────────────

# Anthropic API Key (for the AI Copilot chat feature)
# Get yours at: https://console.anthropic.com/settings/api-keys
VITE_ANTHROPIC_API_KEY=your_api_key_here

# App URL (update when you deploy)
VITE_APP_URL=http://localhost:5173
